{
  "name": "jw-mcp",
  "version": "1.1.0",
  "description": "MCP server for JW.org content: Bible scripture lookup with study content, workbook materials, Watchtower articles, and video captions",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "start:http": "MCP_TRANSPORT=http node src/index.js"
  },
  "bin": {
    "jw-mcp": "./src/index.js"
  },
  "files": [
    "src/"
  ],
  "keywords": [
    "mcp",
    "mcp-server",
    "jw",
    "jw.org",
    "bible",
    "scripture",
    "watchtower",
    "study-notes",
    "wol"
  ],
  "author": "advenimus",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/advenimus/jw-mcp.git"
  },
  "homepage": "https://github.com/advenimus/jw-mcp#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.21.1",
    "cheerio": "^1.1.2",
    "node-fetch": "^3.3.2",
    "express": "^4.18.2",
    "cors": "^2.8.5"
  },
  "devDependencies": {
    "@types/node": "^20.0.0"
  }
}
